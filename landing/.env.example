# Landing page environment variables
# Copy this to .env.local for local development
# Set these as Environment Variables in your Render static site dashboard

# Backend API URL (your Render web service URL)
VITE_API_URL=https://drapeai-wnum.onrender.com

# Google Analytics 4 — get from analytics.google.com
# Format: G-XXXXXXXXXX
VITE_GA4_ID=G-XXXXXXXXXX

# Microsoft Clarity — get from clarity.microsoft.com
# Format: 10-character project ID
VITE_CLARITY_ID=xxxxxxxxxx
